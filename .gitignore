# Pipeline output
output/
logs/
benchmarks/

# Snakemake internals
.snakemake/

# AUGUSTUS config (copied from container at runtime)
augustus_config/

# Singularity images and cache
*.sif
.singularity_cache/

# Shared data (downloaded at runtime)
shared_data/

# Test results (local only)
galba_reference_test/
test_scenarios/*/output/
test_scenarios/*/logs/
test_scenarios/*/benchmarks/
test_scenarios/*/augustus_config/
test_scenarios/*/shared_data/
test_scenarios/*/.snakemake/
test_scenarios/*/.ncbi/

# AGAT/BUSCO stray logs
*.agat.log
busco_*.log

# Python bytecode
__pycache__/
*.pyc

# OS files
.DS_Store
Thumbs.db

# Editor files
*.swp
*.swo
*~
.cache/

# Per-scenario run logs and stray outputs
test_scenarios*/**/run.log
test_scenarios*/**/galba*.log
test_scenarios*/**/busco_downloads_online/

# Local developer-only test scenarios not part of the tracked test suite
test_scenarios_local/scenario_02_red/
test_scenarios_local/scenario_03_busco_online/
test_scenarios_local/scenario_04_busco_offline/

